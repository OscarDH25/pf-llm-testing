{
  "name": "pf-llm-testing-app",
  "version": "0.1.0",
  "private": true,
  "description": "Initial backend for the pf_llm_testing portfolio project.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test:api": "playwright test",
    "test:llm": "playwright test --config playwright.llm.config.js",
    "test:llm:mock": "playwright test --config playwright.llm.mock.config.js",
    "eval:ask": "node evals/run-ask-evals.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
